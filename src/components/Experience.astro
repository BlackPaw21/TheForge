---
// src/components/Experience.astro
import experience from '../data/experience.json';
---

<section id="experience" class="section">
  <div class="container">
    <p class="section-label reveal">03 / EXPERIENCE</p>
    <h2 class="section-title reveal">TIMELINE</h2>
    <div class="timeline">
      {experience.map((entry, i) => (
        <div class={`timeline-entry reveal ${i % 2 === 0 ? 'left' : 'right'}`}>
          <div class="timeline-year">{entry.year}</div>
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3 class="timeline-role">{entry.role}</h3>
            <div class="timeline-org">{entry.org}</div>
            <p class="timeline-desc">{entry.description}</p>
          </div>
        </div>
      ))}
      <div class="timeline-line"></div>
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }
  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--border);
    transform: translateX(-50%);
  }
  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr 24px 1fr;
    align-items: center;
    gap: 24px;
    margin-bottom: 48px;
    position: relative;
  }
  .timeline-dot {
    width: 10px; height: 10px;
    background: var(--blood);
    border: 2px solid var(--void);
    outline: 1px solid var(--blood);
    border-radius: 50%;
    z-index: 1;
    justify-self: center;
  }
  .timeline-entry.left .timeline-year { text-align: right; }
  .timeline-entry.left .timeline-content { grid-column: 3; }
  .timeline-entry.left .timeline-year { grid-column: 1; }
  .timeline-entry.left .timeline-dot { grid-column: 2; }
  .timeline-entry.right { direction: rtl; }
  .timeline-entry.right > * { direction: ltr; }

  .timeline-year {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--blood);
    letter-spacing: 2px;
  }
  .timeline-content {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 20px;
  }
  .timeline-role {
    font-family: var(--font-display);
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--text);
    margin-bottom: 4px;
  }
  .timeline-org {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--blood);
    margin-bottom: 10px;
  }
  .timeline-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
  }

  @media (max-width: 600px) {
    .timeline-line { left: 10px; }
    .timeline-entry {
      grid-template-columns: 20px 1fr;
      direction: ltr !important;
    }
    .timeline-year { display: none; }
    .timeline-dot { grid-column: 1; }
    .timeline-content { grid-column: 2; }
  }
</style>
