---
interface Props {
  title: string;
  date: Date;
  tags: string[];
  difficulty?: string;
  source: string;
  external_url?: string;
  slug?: string;
  excerpt: string;
}

const { title, date, tags, difficulty, source, external_url, slug, excerpt } = Astro.props;

const isExternal = source !== 'local';
const href = isExternal ? external_url! : `/writeups/${slug}`;

const sourceColors: Record<string, string> = {
  htb:    '#9fef00',
  medium: '#fff',
  github: '#6e40c9',
  local:  'var(--blood)',
};
const sourceColor = sourceColors[source] ?? 'var(--blood)';

const difficultyColors: Record<string, string> = {
  easy:   '#00cc44',
  medium: '#ffaa00',
  hard:   '#ff2020',
};
const diffColor = difficulty ? difficultyColors[difficulty] : 'transparent';

const dateStr = date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={href} target={isExternal ? '_blank' : '_self'} rel={isExternal ? 'noopener' : ''} class="writeup-card reveal">
  <div class="card-top">
    <div class="card-meta">
      <span class="card-date">{dateStr}</span>
      {difficulty && <span class="card-diff" style={`color:${diffColor};border-color:${diffColor}`}>{difficulty}</span>}
    </div>
    <span class="card-source" style={`color:${sourceColor};border-color:${sourceColor}`}>
      {source}{isExternal ? ' ↗' : ''}
    </span>
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-excerpt">{excerpt}</p>
  <div class="card-tags">
    {tags.map(t => <span class="tag">{t}</span>)}
  </div>
</a>

<style>
  .writeup-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px;
    transition: border-color 100ms, background 100ms;
    position: relative;
  }
  .writeup-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--blood);
    transition: width 100ms;
  }
  .writeup-card:hover {
    border-color: var(--blood);
    background: var(--elevated);
  }
  .writeup-card:hover::before { width: 3px; }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .card-meta { display: flex; align-items: center; gap: 10px; }
  .card-date { font-size: 10px; color: var(--muted); letter-spacing: 1px; }
  .card-diff, .card-source {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 2px 6px;
    border: 1px solid;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--text);
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .card-excerpt {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .card-tags { display: flex; flex-wrap: wrap; gap: 6px; }
</style>
