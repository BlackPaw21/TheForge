---
// src/components/Arsenal.astro
import projects from '../data/projects.json';
---

<section id="arsenal" class="section">
  <div class="container">
    <p class="section-label reveal">02 / ARSENAL</p>
    <h2 class="section-title reveal">PROJECTS</h2>
    <div class="arsenal-grid">
      {projects.map(p => (
        <div class="project-card reveal">
          <div class="project-card-inner">
            <div class="project-header">
              <span class="project-icon">// </span>
              <h3 class="project-name">{p.name}</h3>
            </div>
            <p class="project-desc">{p.description}</p>
            <div class="project-tags">
              {p.tags.map(t => <span class="tag">{t}</span>)}
            </div>
            <div class="project-footer">
              {p.stars > 0 && <span class="project-stars">★ {p.stars}</span>}
              <a href={p.repo_url} target="_blank" rel="noopener" class="project-link">
                VIEW REPO →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .arsenal-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
  }
  .project-card {
    border: 1px solid var(--border);
    background: var(--surface);
    transition: border-color 100ms, background 100ms;
    position: relative;
  }
  .project-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--blood);
    transition: width 100ms;
  }
  .project-card:hover {
    border-color: var(--blood);
    background: var(--elevated);
  }
  .project-card:hover::before { width: 3px; }
  .project-card-inner {
    padding: 28px;
  }
  .project-header {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-bottom: 12px;
  }
  .project-icon {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--blood);
  }
  .project-name {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: 2px;
    color: var(--text);
  }
  .project-desc {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 16px;
    min-height: 40px;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 20px;
  }
  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid var(--border);
    padding-top: 16px;
  }
  .project-stars {
    font-size: 11px;
    color: var(--muted);
  }
  .project-link {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--blood);
    text-transform: uppercase;
    transition: letter-spacing 100ms;
  }
  .project-link:hover { letter-spacing: 3px; }
</style>
