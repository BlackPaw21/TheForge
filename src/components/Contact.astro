---
// src/components/Contact.astro
const links = [
  { label: 'GitHub',     href: 'https://github.com/BlackPaw',            handle: '@BlackPaw' },
  { label: 'HackTheBox', href: 'https://hackthebox.com/profile/0',       handle: 'BlackPaw' },
  { label: 'Email',      href: 'mailto:betai1357@gmail.com',             handle: 'betai1357@gmail.com' },
];
---

<section id="contact" class="section">
  <div class="container">
    <p class="section-label reveal">05 / CONTACT</p>
    <h2 class="section-title reveal">GET IN<br />TOUCH</h2>
    <p class="contact-sub reveal">
      No recruiters. Security researchers, collaborators, and people<br />
      who've found something interesting — welcome.
    </p>
    <div class="contact-links reveal">
      {links.map(l => (
        <a href={l.href} target="_blank" rel="noopener" class="contact-link">
          <span class="contact-link-label">{l.label}</span>
          <span class="contact-link-handle">{l.handle}</span>
          <span class="contact-link-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-sub {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 48px;
  }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    max-width: 480px;
  }
  .contact-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    transition: border-color 100ms, background 100ms;
    position: relative;
  }
  .contact-link::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 0;
    background: var(--blood);
    transition: width 100ms;
  }
  .contact-link:hover {
    border-color: var(--blood);
    background: var(--elevated);
  }
  .contact-link:hover::before { width: 3px; }
  .contact-link-label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--blood);
    min-width: 100px;
  }
  .contact-link-handle {
    font-size: 12px;
    color: var(--muted);
    flex: 1;
    padding: 0 16px;
  }
  .contact-link-arrow {
    color: var(--muted);
    font-size: 14px;
    transition: transform 100ms, color 100ms;
  }
  .contact-link:hover .contact-link-arrow {
    transform: translateX(4px);
    color: var(--text);
  }
</style>
