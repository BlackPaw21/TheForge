---
// src/pages/tools/index.astro
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import tools from '../../data/tools.json';

const active   = tools.filter(t => t.status === 'active');
const archived = tools.filter(t => t.status === 'archived');
---

<Base title="Tools — BlackPaw's Forge">
  <div class="page-header">
    <div class="container">
      <p class="section-label">TOOLS</p>
      <h1 class="page-title">RELEASED<br />ARSENAL</h1>
      <p class="page-sub">
        Open-source tools, PoCs, and utilities built for offensive work.
      </p>
    </div>
  </div>

  <div class="container page-body">
    {active.length > 0 && (
      <div class="tools-group">
        <div class="group-label">ACTIVE</div>
        <div class="tools-grid">
          {active.map(t => <ToolCard {...t} />)}
        </div>
      </div>
    )}
    {archived.length > 0 && (
      <div class="tools-group">
        <div class="group-label">ARCHIVED</div>
        <div class="tools-grid">
          {archived.map(t => <ToolCard {...t} />)}
        </div>
      </div>
    )}
  </div>
</Base>

<style>
  .page-header {
    padding: calc(var(--nav-height) + 60px) 0 60px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 60px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 96px);
    letter-spacing: 4px;
    color: var(--text);
    margin-bottom: 16px;
  }
  .page-sub { font-size: 13px; color: var(--muted); line-height: 1.9; max-width: 480px; }
  .page-body { padding-bottom: 100px; }
  .tools-group { margin-bottom: 60px; }
  .group-label {
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--blood);
    text-transform: uppercase;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }
  .tools-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
  }
</style>
