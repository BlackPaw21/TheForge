---
// src/pages/writeups/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const writeups = await getCollection('writeups', w => w.data.source === 'local');
  return writeups.map(w => ({ params: { slug: w.id } }));
}

const { slug } = Astro.params;
const allWriteups = await getCollection('writeups');
const entry = allWriteups.find(w => w.id === slug);
if (!entry) return Astro.redirect('/writeups');

const { Content } = await render(entry);

const dateStr = entry.data.date.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---

<Base title={`${entry.data.title} — BlackPaw's Forge`} description={entry.data.excerpt}>
  <div class="writeup-page">
    <div class="writeup-header">
      <div class="container">
        <a href="/writeups" class="back-link">← WRITEUPS</a>
        <div class="writeup-meta">
          <span class="meta-date">{dateStr}</span>
          {entry.data.difficulty && (
            <span class="meta-diff">{entry.data.difficulty}</span>
          )}
          <div class="meta-tags">
            {entry.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
        <h1 class="writeup-title">{entry.data.title}</h1>
        <p class="writeup-excerpt">{entry.data.excerpt}</p>
      </div>
    </div>

    <div class="container writeup-body">
      <article class="prose">
        <Content />
      </article>
    </div>
  </div>
</Base>

<style>
  .writeup-page { padding-bottom: 100px; }
  .writeup-header {
    padding: calc(var(--nav-height) + 60px) 0 60px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 60px;
  }
  .back-link {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 32px;
    transition: color 100ms;
  }
  .back-link:hover { color: var(--blood); }
  .writeup-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .meta-date { font-size: 11px; color: var(--muted); }
  .meta-diff {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 2px 6px;
    border: 1px solid var(--blood);
    color: var(--blood);
  }
  .meta-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .writeup-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 72px);
    letter-spacing: 3px;
    color: var(--text);
    margin-bottom: 16px;
  }
  .writeup-excerpt {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.8;
    max-width: 600px;
  }

  /* Markdown prose styles */
  .prose { max-width: 720px; }
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 28px;
    letter-spacing: 3px;
    color: var(--text);
    margin: 48px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 20px;
    letter-spacing: 2px;
    color: var(--blood);
    margin: 32px 0 12px;
  }
  .prose :global(p) {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 20px;
  }
  .prose :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blood);
    padding: 20px;
    overflow-x: auto;
    margin: 24px 0;
    font-size: 13px;
    line-height: 1.6;
  }
  .prose :global(code:not(pre code)) {
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 2px 6px;
    font-size: 12px;
    color: var(--blood);
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: 24px;
    margin-bottom: 20px;
  }
  .prose :global(li) {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.9;
    margin-bottom: 4px;
  }
  .prose :global(a) {
    color: var(--blood);
    border-bottom: 1px solid var(--blood-dark);
    transition: color 100ms;
  }
  .prose :global(a:hover) { color: var(--text); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--blood);
    padding: 12px 20px;
    background: var(--surface);
    margin: 24px 0;
  }
  .prose :global(blockquote p) { margin-bottom: 0; }
</style>
